# Copy file ini ke .env dan isi nilainya. JANGAN commit .env ke git manapun.

# Helius RPC — https://dashboard.helius.dev
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Wallet — GUNAKAN DEDICATED HOT WALLET, JANGAN wallet utama.
# Private key dalam format base58 (bisa export dari Phantom/Solflare, atau generate baru khusus untuk bot ini).
WALLET_PRIVATE_KEY=

# GMGN — isi jika gmgn-cli/API butuh API key. Setup harus dikonfirmasi manual, jangan auto-generate.
GMGN_API_KEY=

# Telegram — bot token dari BotFather, chat_id supergroup (biasanya angka negatif, misal -1001234567890)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
